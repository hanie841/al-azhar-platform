    "testimonial3Quote": "\u0627\u0644\u0627\u0632\u06c1\u0631 \u0645\u06cc\u06ba \u062c\u062f\u06cc\u062f \u0633\u0627\u0626\u0646\u0633 \u0627\u0648\u0631 \u0627\u0633\u0644\u0627\u0645\u06cc \u0627\u0642\u062f\u0627\u0631 \u06a9\u0627 \u062a\u0648\u0627\u0632\u0646 \u0628\u06d2 \u0645\u062b\u0627\u0644 \u06c1\u06d2\u06d4 \u0645\u06cc\u06ba \u0641\u062e\u0631 \u06a9\u0631\u062a\u0627 \u06c1\u0648\u06ba\u06d4",
