APP_NAME="Al-Azhar Platform"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.al-azhar-platform.com

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=al_azhar
DB_USERNAME=
DB_PASSWORD=

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

SANCTUM_STATEFUL_DOMAINS=al-azhar-platform.vercel.app
SESSION_DOMAIN=.al-azhar-platform.com

CORS_ALLOWED_ORIGINS=https://al-azhar-platform.vercel.app

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
